rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Existing user data — owner only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public profiles — anyone authenticated can read, only owner writes
    match /userProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Market listings — authenticated read, Cloud Functions write only
    match /marketListings/{listingId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Community prayer requests — authenticated read, owner can create, Functions update
    match /prayerRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                     && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Prayer subcollection for tracking who prayed
    match /prayerRequests/{requestId}/prayers/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Community events — authenticated read, Cloud Functions manage
    match /communityEvents/{eventId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
